class Solution {
public:
    ListNode* curr;  

    bool solve(ListNode* head) {
        if (head == NULL)
            return true;

        bool ans = solve(head->next);  

        if (head->val != curr->val)
            return false;

        curr = curr->next;

        return ans;
    }

    bool isPalindrome(ListNode* head) {
        curr = head;
        return solve(head);   
    }
};
